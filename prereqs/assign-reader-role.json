{
    "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "metadata": {
        "description": "Subscription-scope template that grants the Reader role on the subscription to the Microsoft Cognitive Services (CSRP) service principal. Required prerequisite for Azure Context Cache containers until the built-in CSRP role definition rolls out globally."
    },
    "parameters": {
        "principalObjectId": {
            "type": "string",
            "metadata": {
                "description": "Object ID of the Microsoft Cognitive Services enterprise application (App ID 7d312290-28c8-473c-a0ed-8e53749b6d6d) in your tenant."
            }
        }
    },
    "variables": {
        "readerRoleDefinitionId": "acdd72a7-3385-48ef-bd42-f606fba81ae7"
    },
    "resources": [
        {
            "type": "Microsoft.Authorization/roleAssignments",
            "apiVersion": "2022-04-01",
            "name": "[guid(subscription().id, parameters('principalObjectId'), variables('readerRoleDefinitionId'))]",
            "properties": {
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('readerRoleDefinitionId'))]",
                "principalId": "[parameters('principalObjectId')]",
                "principalType": "ServicePrincipal"
            }
        }
    ],
    "outputs": {
        "roleAssignmentId": {
            "type": "string",
            "value": "[subscriptionResourceId('Microsoft.Authorization/roleAssignments', guid(subscription().id, parameters('principalObjectId'), variables('readerRoleDefinitionId')))]"
        }
    }
}
