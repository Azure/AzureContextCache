{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "metadata": {
        "_generator": {
            "name": "azure-context-cache-quickstart",
            "version": "1.1.0"
        },
        "description": "One-click deployment for an Azure Context Cache account + container, with optional creation/update of an Azure OpenAI deployment linked to that container via properties.contextCacheContainerId."
    },
    "parameters": {
        "accountName": {
            "type": "string",
            "defaultValue": "[concat('cc', uniqueString(resourceGroup().id))]",
            "minLength": 3,
            "maxLength": 24,
            "metadata": {
                "description": "Context Cache account name. 3-24 chars: lowercase letters, digits, hyphens; must start/end with letter or digit."
            }
        },
        "containerName": {
            "type": "string",
            "defaultValue": "default-container",
            "minLength": 3,
            "maxLength": 63,
            "metadata": {
                "description": "Context Cache container name. 3-63 chars."
            }
        },
        "location": {
            "type": "string",
            "defaultValue": "centralus",
            "allowedValues": [
                "centralus",
                "swedencentral"
            ],
            "metadata": {
                "description": "Region for the Context Cache resources. 'centralus' is the launch region; 'swedencentral' is also supported."
            }
        },
        "accountKind": {
            "type": "string",
            "defaultValue": "Regional",
            "allowedValues": [
                "Regional",
                "DataZone",
                "Global"
            ],
            "metadata": {
                "description": "Account kind for the Context Cache account."
            }
        },
        "modelName": {
            "type": "string",
            "defaultValue": "gpt-5.4",
            "metadata": {
                "description": "Model name to bind to the cache container (e.g. gpt-5.4, gpt-4o)."
            }
        },
        "provider": {
            "type": "string",
            "defaultValue": "OpenAI",
            "allowedValues": [
                "OpenAI"
            ],
            "metadata": {
                "description": "Model provider. OpenAI is currently the only supported value."
            }
        },
        "timeToLiveDays": {
            "type": "int",
            "defaultValue": 7,
            "minValue": 1,
            "maxValue": 30,
            "metadata": {
                "description": "Container cache entry time-to-live, in days."
            }
        },
        "existingAzureOpenAIAccountName": {
            "type": "string",
            "defaultValue": "",
            "metadata": {
                "description": "Optional. Name of an existing Azure OpenAI account in this resource group. When provided AND createOrUpdateAoaiDeployment is true, a deployment linked to the new context cache container is created/updated under it. Must be in the same region as the context cache container."
            }
        },
        "createOrUpdateAoaiDeployment": {
            "type": "bool",
            "defaultValue": false,
            "metadata": {
                "description": "If true and existingAzureOpenAIAccountName is set, creates/updates an AOAI deployment with properties.contextCacheContainerId pointing at the new container."
            }
        },
        "aoaiDeploymentName": {
            "type": "string",
            "defaultValue": "context-cache-deployment",
            "metadata": {
                "description": "Name of the AOAI deployment to create/update."
            }
        },
        "aoaiModelFormat": {
            "type": "string",
            "defaultValue": "OpenAI",
            "metadata": {
                "description": "AOAI deployment model.format."
            }
        },
        "aoaiModelName": {
            "type": "string",
            "defaultValue": "gpt-5.4",
            "metadata": {
                "description": "AOAI deployment model.name. Should match modelName."
            }
        },
        "aoaiModelVersion": {
            "type": "string",
            "defaultValue": "2026-03-05-contextcache",
            "metadata": {
                "description": "AOAI deployment model.version. Must be a context-cache-capable version."
            }
        },
        "aoaiSkuName": {
            "type": "string",
            "defaultValue": "Standard",
            "metadata": {
                "description": "AOAI deployment SKU name."
            }
        },
        "aoaiSkuCapacity": {
            "type": "int",
            "defaultValue": 100,
            "metadata": {
                "description": "AOAI deployment SKU capacity (TPM units)."
            }
        },
        "tagsByResource": {
            "type": "object",
            "defaultValue": {
                "environment": "demo",
                "sample": "azure-context-cache-quickstart"
            },
            "metadata": {
                "description": "Tags applied to created resources."
            }
        }
    },
    "variables": {
        "associateAoai": "[not(empty(parameters('existingAzureOpenAIAccountName')))]",
        "deployAoaiDeployment": "[and(variables('associateAoai'), parameters('createOrUpdateAoaiDeployment'))]",
        "containerResourceId": "[resourceId('Microsoft.AzureContextCache/accounts/containers', parameters('accountName'), parameters('containerName'))]"
    },
    "resources": [
        {
            "type": "Microsoft.AzureContextCache/accounts",
            "apiVersion": "2026-01-01-preview",
            "name": "[parameters('accountName')]",
            "location": "[parameters('location')]",
            "tags": "[parameters('tagsByResource')]",
            "properties": {
                "accountKind": "[parameters('accountKind')]",
                "description": "Context Cache account provisioned via azure-context-cache-quickstart"
            },
            "resources": [
                {
                    "type": "containers",
                    "apiVersion": "2026-01-01-preview",
                    "name": "[parameters('containerName')]",
                    "dependsOn": [
                        "[resourceId('Microsoft.AzureContextCache/accounts', parameters('accountName'))]"
                    ],
                    "properties": {
                        "description": "[concat('Prompt cache container for ', parameters('modelName'))]",
                        "modelName": "[parameters('modelName')]",
                        "provider": "[parameters('provider')]",
                        "timeToLive": "[parameters('timeToLiveDays')]"
                    }
                }
            ]
        },
        {
            "condition": "[variables('deployAoaiDeployment')]",
            "type": "Microsoft.CognitiveServices/accounts/deployments",
            "apiVersion": "2026-03-15-preview",
            "name": "[concat(parameters('existingAzureOpenAIAccountName'), '/', parameters('aoaiDeploymentName'))]",
            "dependsOn": [
                "[resourceId('Microsoft.AzureContextCache/accounts/containers', parameters('accountName'), parameters('containerName'))]"
            ],
            "sku": {
                "name": "[parameters('aoaiSkuName')]",
                "capacity": "[parameters('aoaiSkuCapacity')]"
            },
            "properties": {
                "model": {
                    "format": "[parameters('aoaiModelFormat')]",
                    "name": "[parameters('aoaiModelName')]",
                    "version": "[parameters('aoaiModelVersion')]"
                },
                "contextCacheContainerId": "[variables('containerResourceId')]"
            }
        }
    ],
    "outputs": {
        "contextCacheAccountId": {
            "type": "string",
            "value": "[resourceId('Microsoft.AzureContextCache/accounts', parameters('accountName'))]"
        },
        "contextCacheAccountName": {
            "type": "string",
            "value": "[parameters('accountName')]"
        },
        "containerId": {
            "type": "string",
            "value": "[variables('containerResourceId')]"
        },
        "containerName": {
            "type": "string",
            "value": "[parameters('containerName')]"
        },
        "modelName": {
            "type": "string",
            "value": "[parameters('modelName')]"
        },
        "associatedAzureOpenAIAccountId": {
            "type": "string",
            "value": "[if(variables('associateAoai'), resourceId('Microsoft.CognitiveServices/accounts', parameters('existingAzureOpenAIAccountName')), '')]"
        },
        "associatedAzureOpenAIEndpoint": {
            "type": "string",
            "value": "[if(variables('associateAoai'), reference(resourceId('Microsoft.CognitiveServices/accounts', parameters('existingAzureOpenAIAccountName')), '2024-10-01', 'Full').properties.endpoint, '')]"
        },
        "aoaiDeploymentId": {
            "type": "string",
            "value": "[if(variables('deployAoaiDeployment'), resourceId('Microsoft.CognitiveServices/accounts/deployments', parameters('existingAzureOpenAIAccountName'), parameters('aoaiDeploymentName')), '')]"
        },
        "aoaiDeploymentName": {
            "type": "string",
            "value": "[if(variables('deployAoaiDeployment'), parameters('aoaiDeploymentName'), '')]"
        },
        "nextSteps": {
            "type": "string",
            "value": "[concat('Context Cache container ready: ', variables('containerResourceId'), '. ', if(variables('deployAoaiDeployment'), concat('AOAI deployment ', parameters('aoaiDeploymentName'), ' is linked to this container.'), 'To link an AOAI deployment, PUT properties.contextCacheContainerId = <containerId> on a Microsoft.CognitiveServices/accounts/deployments resource (api-version 2026-03-15-preview).'))]"
        }
    }
}
